# Backend HTTP, data-service, cache, persistence, and JWT configuration.
# Copy to .env for local use and replace the development signing secret before
# any production deployment.

NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://editor:editor_password@localhost:5432/collab_editor
REDIS_URL=redis://localhost:6379
ACTIVE_DOCUMENT_CACHE_TTL_SECONDS=86400
DOCUMENT_PERSIST_DEBOUNCE_MS=1000
DOCUMENT_PERSIST_RETRY_MS=5000
JWT_SECRET=change-this-development-secret
JWT_EXPIRES_IN_SECONDS=3600
